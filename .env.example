# ─── Pipeline settings ────────────────────────────────────────────────────────
DATA_ROOT=C:\Users\BIT\OneDrive\Documents\CCTV\CCTV Footage
OUTPUT_DIR=./output

# ─── Detection ────────────────────────────────────────────────────────────────
YOLO_MODEL=yolov8s.pt
YOLO_CONF=0.25
YOLO_DEVICE=cpu                  # set to 0 for GPU

# ─── ReID ─────────────────────────────────────────────────────────────────────
REID_MODEL=osnet_x0_25
REID_MATCH_THRESHOLD=0.75
REID_NEW_ID_THRESHOLD=0.55

# ─── Staff Detection ──────────────────────────────────────────────────────────
STAFF_SCORE_THRESHOLD=3
STORE_OPEN_HOUR=9                 # 09:00 local time

# ─── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./store_intelligence.db

# ─── Anomaly Thresholds ───────────────────────────────────────────────────────
QUEUE_SPIKE_SIGMA=2.0
CONVERSION_DROP_PCT=15.0
DEAD_ZONE_MINUTES=60
STALE_FEED_MINUTES=10
